{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "dotnet run --project api",
    "start_watch": "dotnet run watch  --project api",
    "start_dev": "dotnet run environment=development --project api",
    "start_dev_watch": "dotnet run watch environment=development --project api",
    "install_Ef": "cd scripts && bash dotnet_EF_Install.bash",
    "update_db": "dotnet ef database update -s api -p persistence",
    "add_migration": "cd scripts && bash add_migrations.bash",
    "remove_migration": "dotnet ef migrations remove -s api -p persistence",
    "restore": "dotnet restore"
  },
  "author": "Amor III Novilunio"
}
